# Copy to .env and fill in real values. Never commit .env.

# --- Core ---
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# --- Auth (generate strong random values, e.g. `openssl rand -hex 32`) ---
ACCESS_TOKEN_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me

# --- PDF rendering (Browserless Chrome, started by compose.dev.yml) ---
CHROME_URL=ws://localhost:8080
CHROME_TOKEN=chrome_token

# --- Object storage (MinIO in dev, any S3-compatible store in prod) ---
STORAGE_URL=http://localhost:9000/default
STORAGE_ENDPOINT=localhost
STORAGE_PORT=9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=default
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false

# --- Mail ---
MAIL_FROM=noreply@localhost

# --- AI (optional — AI import & job matching degrade gracefully without it) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- One-time super-admin seed (used by `pnpm seed:admin`) ---
# SEED_ADMIN_EMAIL=you@example.com
# SEED_ADMIN_PASSWORD=change-me
# SEED_ADMIN_NAME=Platform Admin
